{
	"info": {
		"_postman_id": "vendor-management-collection",
		"name": "CampusCart Vendor Management API",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:5000/api/health",
					"host": ["http://localhost:5000"],
					"path": ["api", "health"]
				},
				"description": "Check if server is running"
			}
		},
		{
			"name": "User Registration",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"student@campuscart.com\",\n  \"password\": \"password123\",\n  \"university\": \"507f1f1c9e1b800000c7b5112e61a\"\n}"
				},
				"url": {
					"raw": "http://localhost:5000/api/auth/register",
					"host": ["http://localhost:5000"],
					"path": ["api", "auth", "register"]
				},
				"description": "Register a new user account"
			}
		},
		{
			"name": "User Login",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"student@campuscart.com\",\n  \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "http://localhost:5000/api/auth/login",
					"host": ["http://localhost:5000"],
					"path": ["api", "auth", "login"]
				},
				"description": "Login user and get JWT token"
			}
		},
		{
			"name": "Submit Vendor Application",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{userToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"storeName\": \"Tech Store Campus\",\n  \"description\": \"Your one-stop tech shop for all campus needs\",\n  \"address\": \"123 Campus Drive, University Area\",\n  \"phone\": \"+234-567-8900\",\n  \"universityNear\": \"University of Lagos\",\n  \"legalDocuments\": [\n    {\n      \"documentType\": \"business_license\",\n      \"documentUrl\": \"https://example.com/license.pdf\"\n    },\n    {\n      \"documentType\": \"tax_certificate\",\n      \"documentUrl\": \"https://example.com/tax.pdf\"\n    }\n  ],\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [3.3792, 6.9722]\n  }\n}"
				},
				"url": {
					"raw": "http://localhost:5000/api/vendors/apply",
					"host": ["http://localhost:5000"],
					"path": ["api", "vendors", "apply"]
				},
				"description": "Submit vendor application for admin approval"
			}
		},
		{
			"name": "Get Vendor Applications (Admin)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"url": {
					"raw": "http://localhost:5000/api/admin/vendors/applications?status=pending",
					"host": ["http://localhost:5000"],
					"path": ["api", "admin", "vendors", "applications"]
				},
				"description": "Get all pending vendor applications (admin only)"
			}
		},
		{
			"name": "Approve Vendor Application (Admin)",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"rejectionReason\": \"All documents verified and business looks legitimate\"\n}"
				},
				"url": {
					"raw": "http://localhost:5000/api/admin/vendors/applications/{{vendorId}}/approve",
					"host": ["http://localhost:5000"],
					"path": ["api", "admin", "vendors", "applications", "{{vendorId}}", "approve"]
				},
				"description": "Approve vendor application and change user role to vendor"
			}
		},
		{
			"name": "Reject Vendor Application (Admin)",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"rejectionReason\": \"Insufficient business documentation. Please provide updated tax certificate and proof of address.\"\n}"
				},
				"url": {
					"raw": "http://localhost:5000/api/admin/vendors/applications/{{vendorId}}/reject",
					"host": ["http://localhost:5000"],
					"path": ["api", "admin", "vendors", "applications", "{{vendorId}}", "reject"]
				},
				"description": "Reject vendor application with reason"
			}
		},
		{
			"name": "Get Approved Vendors (Public)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "http://localhost:5000/api/vendors/nearby?lng=3.3792&lat=6.9722&radius=5000",
					"host": ["http://localhost:5000"],
					"path": ["api", "vendors", "nearby"]
				},
				"description": "Get approved vendors near a location (public access)"
			}
		},
		{
			"name": "Get Vendor by ID (Public)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "http://localhost:5000/api/vendors/{{vendorId}}",
					"host": ["http://localhost:5000"],
					"path": ["api", "vendors", "{{vendorId}}"]
				},
				"description": "Get specific vendor details (public, only if approved)"
			}
		},
		{
			"name": "Get Products (Public)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"url": {
					"raw": "http://localhost:5000/api/products",
					"host": ["http://localhost:5000"],
					"path": ["api", "products"]
				},
				"description": "Get all products (public access)"
			}
		},
		{
			"name": "Create Product (Vendor)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{vendorToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Laptop Stand\",\n  \"description\": \"Adjustable laptop stand for comfortable studying\",\n  \"price\": 25.99,\n  \"category\": \"Electronics\",\n  \"stockQuantity\": 15,\n  \"images\": [\"https://example.com/laptop-stand.jpg\"]\n}"
				},
				"url": {
					"raw": "http://localhost:5000/api/products",
					"host": ["http://localhost:5000"],
					"path": ["api", "products"]
				},
				"description": "Create a new product (vendor only)"
			}
		},
		{
			"name": "Get Universities (Admin)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"url": {
					"raw": "http://localhost:5000/api/admin/universities",
					"host": ["http://localhost:5000"],
					"path": ["api", "admin", "universities"]
				},
				"description": "Get all universities for admin management"
			}
		},
		{
			"name": "Create University (Admin)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{adminToken}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"name\": \"Test University\",\n  \"location\": {\n    \"type\": \"Point\",\n    \"coordinates\": [7.5255, 4.7534]\n  },\n  \"address\": \"Test University Address\",\n  \"city\": \"Test City\",\n  \"state\": \"Test State\",\n  \"country\": \"Nigeria\"\n}"
				},
				"url": {
					"raw": "http://localhost:5000/api/admin/universities",
					"host": ["http://localhost:5000"],
					"path": ["api", "admin", "universities"]
				},
				"description": "Create a new university (admin only)"
			}
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000",
			"type": "string"
		},
		{
			"key": "userToken",
			"value": "",
			"type": "string",
			"description": "JWT token from user login response"
		},
		{
			"key": "adminToken",
			"value": "",
			"type": "string",
			"description": "JWT token from admin login response"
		},
		{
			"key": "vendorId",
			"value": "",
			"type": "string",
			"description": "Vendor ID from application list or vendor details"
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-set userToken from login response\nif (pm.response.code === 200) {\n    pm.collectionVariables.set('userToken', pm.response.json().data.token);\n}"
				]
			}
		},
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-set adminToken from admin login response\nif (pm.response.code === 200) {\n    pm.collectionVariables.set('adminToken', pm.response.json().data.token);\n}"
				]
			}
		}
	]
}
